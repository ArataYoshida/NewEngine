NewEditor/
NewEngine/
NewLauncher/
NewRomBootstrapper/
NewScriptCore/
NewEditor.AssetImporter/
tools/
CMakeLists.txt
*.cs
*.cpp
*.c
*.h
*.hpp
*.csproj
*.sln
*.xaml
*.ps1
*.bat

# Local outputs and diagnostics.
bin/
obj/
build/
.vs/
.vscode/
.cache/
*.log
